generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                      String                 @id @default(uuid())
  email                   String                 @unique
  username                String                 @unique
  passwordHash            String
  createdAt               DateTime               @default(now())
  updatedAt               DateTime               @updatedAt
  gender                  String?
  birthDate               DateTime?
  weightKg                Int?
  avatarPath              String?
  deletedAt               DateTime?
  deletedById             String?
  deletedBy               User?                  @relation("UserDeletedBy", fields: [deletedById], references: [id])
  deletedUsers            User[]                 @relation("UserDeletedBy")

  workouts                Workout[]
  friendships             Friendship[]           @relation("UserFriendships")
  friendsWith             Friendship[]           @relation("FriendFriendships")
  sessions                Session[]
  challengesCreated       Challenge[]            @relation("UserCreatedChallenges")
  challengeParticipations ChallengeParticipant[]
  Notification            Notification[]
  isAdmin                 Boolean                @default(false)

  profileHistory          UserProfileHistory[]   @relation("UserProfileHistoryUser")
  profileChangesMade      UserProfileHistory[]   @relation("UserProfileChangedBy")
  passwordResetTokens     PasswordResetToken[]
  friendFollows           FriendFollow[]         @relation("FriendFollowFollower")
  followedBy              FriendFollow[]         @relation("FriendFollowFriend")
  workoutReactions        WorkoutReaction[]
  pushSubscriptions       PushSubscription[]
  pushFriendRequest       Boolean                @default(true)
  pushChallengeInvite     Boolean                @default(true)
  pushChallengeRankChange Boolean                @default(true)
  notificationPreferences NotificationPreference[]
  trainingPrograms        TrainingProgram[]
}


model Workout {
  id           String   @id @default(uuid())
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId       String
  date         DateTime
  time         DateTime @default(now())
  exerciseType String
  reps         Int
  trainingSessionId String?
  trainingSession   TrainingSession? @relation(fields: [trainingSessionId], references: [id], onDelete: SetNull)
  reactions         WorkoutReaction[]

  @@index([userId, exerciseType, time])
  @@index([userId, time])
  @@index([trainingSessionId])
}

model WorkoutReaction {
  id        String   @id @default(cuid())
  workoutId String
  userId    String
  emoji     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  workout Workout @relation(fields: [workoutId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([workoutId, userId])
  @@index([workoutId, updatedAt])
  @@index([userId])
}

model Friendship {
  id        String   @id @default(uuid())
  user      User     @relation("UserFriendships", fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  friend    User     @relation("FriendFriendships", fields: [friendId], references: [id], onDelete: Cascade)
  friendId  String
  status    String   @default("accepted") // accepted | pending
  createdAt DateTime @default(now())

  @@unique([userId, friendId])
}

model FriendFollow {
  id         String   @id @default(cuid())
  followerId String
  friendId   String
  createdAt  DateTime @default(now())

  follower User @relation("FriendFollowFollower", fields: [followerId], references: [id], onDelete: Cascade)
  friend   User @relation("FriendFollowFriend", fields: [friendId], references: [id], onDelete: Cascade)

  @@unique([followerId, friendId])
  @@index([friendId])
}

model Session {
  id        String   @id @default(uuid())
  token     String   @unique
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  createdAt DateTime @default(now())
  expiresAt DateTime

  @@index([userId, expiresAt])
}

model Challenge {
  id String @id @default(uuid())

  creatorId String
  creator   User   @relation("UserCreatedChallenges", fields: [creatorId], references: [id])

  name         String
  exerciseType String
  mode         String   @default("most") // most | target | daily_min | sets_min
  targetReps   Int?
  startDate    DateTime
  endDate      DateTime

  createdAt DateTime @default(now())

  participants ChallengeParticipant[]
}

model ChallengeParticipant {
  id String @id @default(uuid())

  challengeId String
  challenge   Challenge @relation(fields: [challengeId], references: [id], onDelete: Cascade)

  userId String
  status String @default("pending") // pending | accepted
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([challengeId, userId])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  type      String // challenge_invite | challenge_accept | challenge_decline
  title     String
  body      String?
  link      String? // например /challenges/<id>
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead, createdAt])
}


model UserProfileHistory {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation("UserProfileHistoryUser", fields: [userId], references: [id], onDelete: Cascade)

  changedById String?
  changedBy   User?    @relation("UserProfileChangedBy", fields: [changedById], references: [id], onDelete: SetNull)

  changedAt   DateTime @default(now())
  changes     Json

  @@index([userId, changedAt])
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String   @unique
  createdAt DateTime @default(now())
  expiresAt DateTime
  usedAt    DateTime?

  @@index([userId, expiresAt])
  @@index([expiresAt, usedAt])
}

model PushSubscription {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  endpoint  String   @unique
  p256dh    String
  auth      String
  userAgent String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, isActive])
}

model NotificationPreference {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  eventType   String
  pushEnabled Boolean  @default(true)
  emailEnabled Boolean @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([userId, eventType])
  @@index([eventType])
}

model TrainingProgram {
  id               String   @id @default(cuid())
  userId           String
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  exerciseType     String
  goalType         String
  targetReps       Int?
  durationWeeks    Int
  frequencyPerWeek Int
  baselineMaxReps  Int
  ageYears         Int
  weightKg         Int
  sex              String
  startDate        DateTime @default(now())
  status           String   @default("active") // active | inactive | needs_retest | completed
  needsRetest      Boolean  @default(false)
  lastRecalculatedAt DateTime?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  isActive         Boolean  @default(true)

  sessions         TrainingSession[]

  @@index([userId, isActive, createdAt])
}

model TrainingSession {
  id           String   @id @default(cuid())
  programId    String
  program      TrainingProgram @relation(fields: [programId], references: [id], onDelete: Cascade)
  weekNumber   Int
  sessionNumber Int
  scheduledAt  DateTime
  isFinalTest  Boolean  @default(false)
  startedAt    DateTime?
  completed    Boolean  @default(false)
  completedAt  DateTime?
  shiftedCount Int      @default(0)
  reminderSentAt DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  sets         TrainingSet[]
  workouts     Workout[]

  @@index([programId, scheduledAt])
  @@index([programId, completed, scheduledAt])
}

model TrainingSet {
  id          String   @id @default(cuid())
  sessionId   String
  session     TrainingSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  setNumber   Int
  targetReps  Int
  actualReps  Int?
  restSeconds Int
  completedAt DateTime?
  isKeySet    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([sessionId, setNumber])
  @@index([sessionId, setNumber])
}
